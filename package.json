{
  "name": "@smartmemory/compose",
  "version": "0.1.16-beta",
  "description": "Structured AI dev pipeline — goal-to-product orchestration with gates, iteration loops, and feature lifecycle management.",
  "author": "SmartMemory",
  "license": "MIT",
  "type": "module",
  "bin": {
    "compose": "./bin/compose.js"
  },
  "exports": {
    "./mcp": "./server/compose-mcp.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "node server/supervisor.js 2>&1 | tee /tmp/compose-server.log",
    "dev:server": "node server/supervisor.js",
    "dev:server:bare": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test test/*.test.js test/comp-obs-branch/*.test.js && npm run test:ui",
    "test:ui": "vitest run",
    "test:integration": "node --test test/integration/*.test.js",
    "test:wave-6": "node --test test/wave-6-integration.test.js test/wave-6-contract-compliance.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "compose",
    "smartmemory",
    "ai",
    "orchestration",
    "agent",
    "pipeline",
    "stratum",
    "claude",
    "codex",
    "cli"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smartmemory/compose.git"
  },
  "bugs": {
    "url": "https://github.com/smartmemory/compose/issues"
  },
  "homepage": "https://github.com/smartmemory/compose#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".compose-deps.json",
    ".claude/skills/**",
    "bin/**",
    "server/**",
    "lib/**",
    "dist/**",
    "templates/**",
    "presets/**",
    "pipelines/**",
    "contracts/**",
    "scripts/**",
    "skills/**",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.47",
    "@dagrejs/dagre": "^2.0.4",
    "@hello-pangea/dnd": "^18.0.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@opencode-ai/sdk": "^1.2.17",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "date-fns": "^3.6.0",
    "diff": "^8.0.4",
    "express": "^4.21.0",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.13.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.1.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "zod": "^4.0.0"
  }
}
